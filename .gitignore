<!-- Profile -->
<div class="text-center">
  <img src="https://source.unsplash.com/100x100/?portrait" class="w-24 h-24 mx-auto rounded-full mb-4">
  <h1 class="text-xl font-bold">Muhammad Nisar</h1>
